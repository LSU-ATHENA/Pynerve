# Auto-detect text files and normalize line endings
* text=auto

*.py text diff=python
*.pyi text diff=python

*.cpp text diff=cpp
*.hpp text
*.h text
*.cuh text
*.cu text diff=cuda

CMakeLists.txt text
*.cmake text

*.sh text eol=lf
*.bash text eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf

*.md text diff=markdown
*.rst text
*.txt text

*.yml text
*.yaml text
*.json text
*.toml text

*.svg -text
*.png -text
*.jpg -text
*.ico -text
*.woff -text
*.woff2 -text

*.so -text
*.dylib -text
*.dll -text
*.pyd -text
*.pyc -text diff=-merge
__pycache__/ -text
*.pyc binary
