@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Threads REQUIRED)

if(@NERVE_HAS_OPENMP@)
    find_dependency(OpenMP REQUIRED COMPONENTS CXX)
endif()

if(@NERVE_HAS_CUDA@)
    find_dependency(CUDAToolkit REQUIRED)
endif()

if(@NERVE_HAS_MPI@)
    find_dependency(MPI REQUIRED COMPONENTS CXX)
endif()

if(@NERVE_HAS_EIGEN3@)
    find_dependency(Eigen3 REQUIRED)
endif()


include("${CMAKE_CURRENT_LIST_DIR}/NerveTargets.cmake")


check_required_components(Nerve)


set(Nerve_HAS_CUDA @NERVE_HAS_CUDA@)
set(Nerve_HAS_PYTHON @BUILD_PYTHON@)
set(Nerve_HAS_MPI @NERVE_HAS_MPI@)
set(Nerve_HAS_EIGEN3 @NERVE_HAS_EIGEN3@)
set(Nerve_HAS_OPENMP @NERVE_HAS_OPENMP@)
set(Nerve_HAS_NUMA @NERVE_HAS_NUMA@)
